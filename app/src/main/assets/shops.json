      "blacklist": []
    },
    "dialogue": {
      "preface": [
        {
          "speaker": "Mechanic",
          "text": "Hey there, Nova! I've been polishing parts since dawn."
        },
        {
          "speaker": "Mechanic",
          "text": "If you're hunting for mod cores, grab them before the scouts do."
        }
      ],
      "smalltalk": [
        {
          "id": "shop_mechanic_stock",
          "label": "Ask what's new",
          "response": [
            {
              "speaker": "Mechanic",
              "text": "Scavvers dragged in a crate of micro-cores—perfect for overclocking your drone."
            },
            {
              "speaker": "Mechanic",
              "text": "I've stashed the best ones under the counter. Ask if you want the premium batch."
            }
          ]
        },
        {
          "id": "shop_mechanic_gossip",
          "label": "Trade rumors",
          "response": [
            {
              "speaker": "Mechanic",
              "text": "Word is the mine tunnel reopened. If you're heading there, reinforce your boots."
            },
            {
              "speaker": "Mechanic",
              "text": "Last crew brought back slagged plating—whatever's down there hits hard."
            }
          ]
        }
      ],
      "trade_label": "Browse the mods",
      "leave_label": "Back to the hub"
    }
  },
