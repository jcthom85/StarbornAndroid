  "mechanic_shop": {
    "name": "Mechanic's Wares",
    "portrait": "images/portraits/mechanic.png",
    "greeting": "Mechanic: Hey there, Nova! I've got parts polished and ready to bolt on.",
    "pricing": {
      "sell_markup": 1.2,
      "buy_markdown": 0.35
    },
    "sells": {
