    {
        "id": "scene_relic_sync",
        "title": "The Tuning Fork Synchronized",
        "steps": [
            {
                "type": "narration",
                "text": "Your hand touches the Tuning Fork. Instantly, the subsystem hum in your teeth flares into a deafening pressure. It isn't sound; it is weight, pushing down from the roof of the chamber."
            },
            {
                "type": "narration",
                "text": "The stone under your fingers doesn't feel solid. It feels like standing waves, a vibration held in place by sheer resonance."
            },
            {
                "type": "narration",
                "text": "A cold current surges up your arm, rippling through your neural link. The old songs in your eyes flicker and warp, replaced by a deep, oceanic pressure."
            },
            {
                "type": "narration",
                "text": "You hear it. Not a protocol error. A song. The Chorus. Standing waves of a resonance older than the colony, pressing against your mind."
            },
            {
                "type": "narration",
                "text": "You pull your hand back as the resonance stabilizes. The hum remains, settled deep in your chest."
            }
        ]
    },
    {
        "id": "scene_launch_crash",
        "title": "Planetary Impact",
        "steps": [
            {
                "type": "narration",
                "text": "The pod clears the magnetic launch rail, shooting up into the upper atmosphere. The glowing canyons of the colony shrink into a tiny gray scar below."
            },
            {
                "type": "narration",
                "text": "Suddenly, the view out the viewport fractures. A blinding web of blue resonance—the planetary shield—flashes in front of you."
            },
            {
                "type": "narration",
                "text": "The pod's hull begins to shriek and buckle as it collides with the shield's standing wave frequency."
            },
            {
                "type": "dialogue",
                "speaker": "Zeke",
                "text": "Nova! Hold on! The navigation console is burning out—the frequency bypass isn't holding!"
            },
            {
                "type": "narration",
                "text": "Alarms scream. The navigation console sparks and dies. Zeke holds onto the frame, yelling over the sound of tearing metal."
            },
            {
                "type": "narration",
                "text": "The shield rejects the pod, throwing it back into the atmosphere in a spinning descent toward the overgrown ruins of Sector 9."
            },
            {
                "type": "narration",
                "text": "Everything goes white as the thrusters fail and the ground rushes up to meet you."
            }
        ]
    },
    {
        "id": "scene_sq04_hack",
        "title": "Protocol Decryption",
        "steps": [
            {
                "type": "narration",
                "text": "You plug your datapad into the console's debugging interface. The screen immediately cascades with thousands of lines of encrypted compiler scripts."
            },
            {
                "type": "narration",
                "text": "A hidden data block decrypts. The signature on the package is marked by standing waves and acoustic patterns, signed by the 'Chorus'."
            },
            {
                "type": "narration",
                "text": "The terminal chimes. 'Protocol override successfully broadcast. Local admin privileges established.'"
            }
        ]
    },
    {
        "id": "scene_sq05_datapad",
        "title": "The Last Shift Logs",
        "steps": [
            {
                "type": "narration",
                "text": "You boot up the discarded datapad. The battery is critically low, but the final text log is intact."
            },
            {
                "type": "narration",
                "text": "Log Entry: 'They sealed the doors from the outside. Said the collapse was a biohazard risk, but we only hit a pocket of hum.'"
            },
            {
                "type": "narration",
                "text": "Log Entry: 'The resonance is beautiful. It doesn't sound like a machine. It sounds like currents in a deep ocean. I'm not afraid of the dark anymore.'"
            },
            {
                "type": "narration",
                "text": "The screen flickers and goes dark permanently, leaving you in the cold silence of the mine."
            }
        ]
    }
]